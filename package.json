{
  "name": "resume-studio",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "vue-tsc -b --noEmit",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts",
    "format": "prettier --write \"src/**/*.{ts,vue,scss,css,json,md}\"",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "dompurify": "^3.2.6",
    "localforage": "^1.10.0",
    "marked": "^18.0.4",
    "md-editor-v3": "^6.5.1",
    "pinia": "^3.0.4",
    "sass": "^1.100.0",
    "vue": "^3.5.35"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^24.13.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.6.2",
    "globals": "^16.5.0",
    "happy-dom": "^18.0.1",
    "prettier": "^3.7.4",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.50.0",
    "vite": "^8.0.16",
    "vitest": "^3.2.4",
    "vue-eslint-parser": "^10.2.0",
    "vue-tsc": "^3.3.3"
  }
}
